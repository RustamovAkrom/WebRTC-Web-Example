# Namuna muhit o'zgaruvchilari. Nusxa oling: cp .env.example .env
# va qiymatlarni o'zgartiring. .env'ni hech qachon git'ga commit qilmang.

# Muhit: dev | prod  (prod'da JWT_SECRET majburiy, cookie Secure bo'lishi kerak)
ENVIRONMENT=dev

# PostgreSQL (docker-compose ichida `db` hostname)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DATABASE_URL=postgresql+asyncpg://app:app@db:5432/app

# JWT imzo kaliti — PROD'da albatta tasodifiy uzun qiymat bering:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me

# Vergul bilan ajratilgan ruxsat etilgan originlar (bo'sh = dev defaultlari)
# Prod misol: CORS_ORIGINS=https://meet.example.com
CORS_ORIGINS=

# HTTPS orqali ishlatilganda cookie'ni Secure qiling
COOKIE_SECURE=false

# Chat xabarlarini DB'ga saqlash (default: o'chiq)
PERSIST_CHAT=false
